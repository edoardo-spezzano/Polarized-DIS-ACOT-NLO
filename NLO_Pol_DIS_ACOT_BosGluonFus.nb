      SubscriptBox["m", "2"], "^", "2"}], "+", 
     RowBox[{
      SubscriptBox["m", "1"], "^", "2"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
