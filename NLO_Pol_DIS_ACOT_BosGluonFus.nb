    RowBox[{
     RowBox[{"variables", "=", 
      RowBox[{"{", 
       RowBox[{"Y0", ",", "Y1", ",", "Y0s", ",", "Y1s"}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Base", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", "\[Zeta]"}], ",", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"\[Zeta]", "-", "1"}], ")"}]}], ",", 
        RowBox[{"1", "/", 
         RowBox[{"\[Zeta]", "^", "2"}]}], ",", 
        RowBox[{"1", "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Zeta]", "-", "1"}], ")"}], "^", "2"}]}]}], "}"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"toBase", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "\[Zeta]"}], "\[Rule]", "Y0"}], ",", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"\[Zeta]", "-", "1"}], ")"}]}], "\[Rule]", "Y1"}], ",", 
