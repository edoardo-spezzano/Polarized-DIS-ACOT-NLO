Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"topaper", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"t", "\[Rule]", " ", 
       RowBox[{
        RowBox[{
         SubscriptBox["m", "1"], "^", "2"}], "-", 
        RowBox[{
         RowBox[{
          RowBox[{"Q", "^", "2"}], "/", 
          RowBox[{"OverHat", "[", "x", "]"}]}], 
         RowBox[{"(", 
          RowBox[{"1", "-", "\[Zeta]"}], ")"}]}]}]}], ",", 
      RowBox[{"u", "\[Rule]", 
       RowBox[{
        RowBox[{
         SubscriptBox["m", "2"], "^", "2"}], "-", " ", 
        RowBox[{"\[Zeta]", " ", 
         RowBox[{
          RowBox[{"Q", "^", "2"}], "/", 
          RowBox[{"OverHat", "[", "x", "]"}]}]}]}]}], ",", 
      RowBox[{"s", "\[Rule]", " ", 
       RowBox[{
        RowBox[{"Q", "^", "2"}], 
        RowBox[{"(", " ", 
         RowBox[{
          RowBox[{"1", "/", 
           RowBox[{"OverHat", "[", "x", "]"}]}], "-", "1"}], ")"}]}]}]}], 
     "}"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"to\[Zeta]", "[", "Hg_", "]"}], ":=", 
    RowBox[{
     RowBox[{"SUNSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ReplaceAll", "[", 
         RowBox[{"Hg", ",", "topaper"}], "]"}], "//", "FullSimplify"}], ",", 
       RowBox[{"SUNNToCACF", "\[Rule]", "False"}]}], "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"SUNN", "\[Rule]", "3"}], ",", 
       RowBox[{
        RowBox[{"SMP", "[", "\"\<e\>\"", "]"}], "\[Rule]", "1"}]}], "}"}]}]}],
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qplus", "=", 
   RowBox[{
    RowBox[{"a", " ", "a1"}], "+", 
    RowBox[{"v", " ", "v1"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
