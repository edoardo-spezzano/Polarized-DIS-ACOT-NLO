Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"SetMandelstam", "[", 
     RowBox[{"s", ",", "t", ",", "u", ",", "q", ",", "p", ",", 
      RowBox[{"-", "k2"}], ",", 
      RowBox[{"-", "k1"}], ",", 
      RowBox[{"I", " ", "Q"}], ",", "0", ",", 
      RowBox[{"SMP", "[", "\"\<m_d\>\"", "]"}], ",", 
      RowBox[{"SMP", "[", "\"\<m_u\>\"", "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "box", " ", "notation", " ", "for", " ", "k1", " ", "and", 
     " ", "k2"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"MakeBoxes", "[", 
      RowBox[{"k1", ",", "TraditionalForm"}], "]"}], 
     ":=", "\"\<\\!\\(\\*SubscriptBox[\\(k\\), \\(1\\)]\\)\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"MakeBoxes", "[", 
      RowBox[{"k2", ",", "TraditionalForm"}], "]"}], 
     ":=", "\"\<\\!\\(\\*SubscriptBox[\\(k\\), \\(2\\)]\\)\>\""}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Generate", " ", "Feynman", " ", "diagram", " ", "topologies", " ", 
     "with", " ", "specific", " ", "vertex", " ", "and", " ", "fermion", " ", 
     "structures"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"LOW", "=", 
     RowBox[{"InsertFields", "[", 
      RowBox[{
       RowBox[{"CreateTopologies", "[", 
        RowBox[{"0", ",", 
         RowBox[{"2", "\[Rule]", "2"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"V", "[", "3", "]"}], ",", 
          RowBox[{"V", "[", "5", "]"}]}], "}"}], "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"F", "[", 
            RowBox[{"3", ",", 
             RowBox[{"{", "1", "}"}]}], "]"}]}], ",", 
          RowBox[{"F", "[", 
           RowBox[{"4", ",", 
            RowBox[{"{", "1", "}"}]}], "]"}]}], "}"}]}], ",", 
       RowBox[{"InsertionLevel", "\[Rule]", 
        RowBox[{"{", "Particles", "}"}]}], ",", 
       RowBox[{"Model", "\[Rule]", "\"\<SMQCD\>\""}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Paint", " ", "the", " ", "generated", " ", "topologies", " ", "with", " ",
      "specific", " ", "layout", " ", "and", " ", "settings"}], "*)"}], "\n", 
   RowBox[{"Paint", "[", 
    RowBox[{"LOW", ",", 
     RowBox[{"ColumnsXRows", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"2", ",", "1"}], "}"}]}], ",", 
     RowBox[{"Numbering", "\[Rule]", "Simple"}], ",", 
     RowBox[{"SheetHeader", "\[Rule]", "None"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"512", ",", "256"}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Convert", " ", "Feynman", " ", "amplitudes"}], ",", 
     RowBox[{"applying", " ", "options", " ", "for", " ", "dimension"}], ",", 
     "polarization", ",", 
     RowBox[{"and", " ", "prefactors"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"convertedAmps", "=", 
     RowBox[{"FCFAConvert", "[", 
      RowBox[{
       RowBox[{"CreateFeynAmp", "[", "LOW", "]"}], ",", 
       RowBox[{"IncomingMomenta", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"q", ",", "p"}], "}"}]}], ",", 
       RowBox[{"OutgoingMomenta", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"k1", ",", "k2"}], "}"}]}], ",", 
       RowBox[{"ChangeDimension", "\[Rule]", "4"}], ",", 
       RowBox[{"List", "\[Rule]", "False"}], ",", 
       RowBox[{"SMP", "\[Rule]", "True"}], ",", 
       RowBox[{"TransversePolarizationVectors", "\[Rule]", 
        RowBox[{"{", "p", "}"}]}], ",", 
       RowBox[{"Contract", "\[Rule]", "True"}], ",", 
       RowBox[{"DropSumOver", "\[Rule]", "True"}], ",", 
       RowBox[{"Prefactor", "\[Rule]", 
        RowBox[{
         RowBox[{"Sqrt", "[", "2", "]"}], "*", 
         RowBox[{
          RowBox[{"SMP", "[", "\"\<sin_W\>\"", "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"SMP", "[", 
             RowBox[{"\"\<V_ud\>\"", ",", 
              RowBox[{"-", "I"}]}], "]"}]}], ")"}]}]}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Replace", " ", "specific", " ", "DiracGamma", " ", "structures", " ", 
     "to", " ", "create", " ", "the", " ", "generic", " ", "type", " ", "of", 
     " ", "the", " ", "interaction"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"substitution1", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        FormBox[
         RowBox[{
          RowBox[{"DiracGamma", "[", 
           RowBox[{"Momentum", "[", 
            RowBox[{"Polarization", "[", 
             RowBox[{"p", ",", "I", ",", 
              RowBox[{"Transversality", "\[Rule]", "True"}]}], "]"}], "]"}], 
           "]"}], ".", 
          RowBox[{"DiracGamma", "[", "7", "]"}]}],
         TraditionalForm], "->", 
        RowBox[{"DiracGamma", "[", 
         RowBox[{"Momentum", "[", 
          RowBox[{"Polarization", "[", 
           RowBox[{"p", ",", "I", ",", 
            RowBox[{"Transversality", "\[Rule]", "True"}]}], "]"}], "]"}], 
         "]"}]}], ",", 
       RowBox[{
        FormBox[
         RowBox[{
          RowBox[{"DiracGamma", "[", 
           RowBox[{"Momentum", "[", 
            RowBox[{"Polarization", "[", 
             RowBox[{"p", ",", "I", ",", 
              RowBox[{"Transversality", "\[Rule]", "True"}]}], "]"}], "]"}], 
           "]"}], ".", 
          RowBox[{"DiracGamma", "[", "6", "]"}]}],
         TraditionalForm], "->", 
        RowBox[{"DiracGamma", "[", 
         RowBox[{"Momentum", "[", 
          RowBox[{"Polarization", "[", 
           RowBox[{"p", ",", "I", ",", 
            RowBox[{"Transversality", "\[Rule]", "True"}]}], "]"}], "]"}], 
         "]"}]}], ",", 
       RowBox[{
        RowBox[{"DiracGamma", "[", "7", "]"}], "\[Rule]", 
        RowBox[{"(", 
         RowBox[{"v", "-", 
          RowBox[{"a", "*", 
           RowBox[{"GA", "[", "5", "]"}]}]}], ")"}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"amp0", "=", 
     RowBox[{"ReplaceAll", "[", 
      RowBox[{"convertedAmps", ",", "substitution1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "M_munu", " ", "tensor", " ", "cutting", " ", 
     "the", " ", "polarization", " ", "vectors"}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"substitution2", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"DiracGamma", "[", 
         RowBox[{"Momentum", "[", 
          RowBox[{"Polarization", "[", 
           RowBox[{"q", ",", "I"}], "]"}], "]"}], "]"}], "\[Rule]", 
        RowBox[{"GA", "[", "\[Mu]", "]"}]}], ",", 
       RowBox[{
