 RowBox[{
  RowBox[{"ApartImproved", "[", "test1_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "variables", ",", "Base", ",", "toBase", ",", "mat", ",", "list", ",", 
