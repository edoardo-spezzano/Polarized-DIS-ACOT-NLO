      RowBox[{
       RowBox[{"a1", " ", "v"}], "+", " ", 
       RowBox[{"a", " ", "v1"}]}], ")"}], "/", "2"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalSigma]pp", "=", 
   RowBox[{
    RowBox[{"Q", "^", "2"}], "+", 
    RowBox[{
     SubscriptBox["m", "2"], "^", "2"}], "+", 
