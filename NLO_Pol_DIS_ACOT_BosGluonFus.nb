Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"PolarizedProjector", "=", " ", 
    RowBox[{
     RowBox[{"I", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"LC", "[", 
         RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Alpha]", ",", "\[Beta]"}], 
         "]"}], ".", 
        RowBox[{"FV", "[", 
         RowBox[{"p", ",", "\[Alpha]"}], "]"}], ".", 
        RowBox[{"FV", "[", 
         RowBox[{"q", ",", "\[Beta]"}], "]"}]}], "/", 
       RowBox[{"(", " ", 
        RowBox[{"2", " ", 
         RowBox[{"SP", "[", 
          RowBox[{"p", ",", "q"}], "]"}]}], ")"}]}]}], "//", "Contract"}]}], 
   ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Definition", " ", "in", " ", "the", " ", "Felix", " ", "Heckorn", " ", 
    "PhD", " ", "Thesis"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EvaluateContraction", "[", 
   RowBox[{"projector1_", ",", "projector2_", ",", "Tensor_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"expression", ",", "simplified"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{
     "General", " ", "approach", " ", "to", " ", "constructing", " ", "the", " ",
       "expression"}], "*)"}], 
    RowBox[{
     RowBox[{"expression", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"projector1", "/.", 
          RowBox[{"{", 
           RowBox[{"\[Nu]", "\[Rule]", "k1"}], "}"}]}], ")"}], ".", 
        RowBox[{"(", 
         RowBox[{"projector2", "/.", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\[Mu]", "\[Rule]", "\[Nu]"}], ",", 
            RowBox[{"\[Nu]", "\[Rule]", "k2"}]}], "}"}]}], ")"}], ".", 
        RowBox[{"(", "Tensor", ")"}], ".", 
        RowBox[{"(", 
         RowBox[{"ComplexConjugate", "[", 
          RowBox[{"ReplaceAll", "[", 
           RowBox[{"Tensor", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Mu]", "\[Rule]", "k1"}], ",", 
              RowBox[{"\[Nu]", "\[Rule]", "k2"}], ",", 
              RowBox[{"v", "\[Rule]", "v1"}], ",", 
              RowBox[{"a", "\[Rule]", "a1"}]}], "}"}]}], "]"}], "]"}], 
         ")"}]}], "//", "Contract"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Simplify", " ", "the", " ", "expression"}], "*)"}], 
     RowBox[{"simplified", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"SUNSimplify", "[", 
         RowBox[{
          RowBox[{"expression", "//", "FeynAmpDenominatorExplicit"}], ",", 
          RowBox[{"Explicit", "\[Rule]", "True"}], ",", 
          RowBox[{"SUNNToCACF", "\[Rule]", "True"}]}], "]"}], "//", 
        "FermionSpinSum"}], "//", 
       RowBox[{"DiracSimplify", "/.", 
        RowBox[{"{", 
         RowBox[{"SUNN", "\[Rule]", "3"}], "}"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "the", " ", "simplified", " ", "expression"}], 
      "*)"}], "simplified"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9404971003885636`*^9, 3.9404971187029457`*^9}, {
