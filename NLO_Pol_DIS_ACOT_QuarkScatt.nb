   RowBox[{"Taylor", " ", "Series", " ", "Expansion", " ", "Order"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Computing"}]}], " ", "the", " ", "massless", " ", "limit",
      " ", "with", " ", "Asymptotic", " ", 
     RowBox[{"method", "--"}]}], "-"}], "*)"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ComputeTotal", "[", "integrand_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "samemass", ",", "f0", ",", "IntegrationOuter", ",", "outer0", ",", 
       "outer1", ",", "outertotal", ",", "inner", ",", "IntegrationInner", ",",
        "inner0", ",", "inner1", ",", "innertotal", ",", "total"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Replace", " ", "subscripted", " ", "masses", " ", "with", " ", "m"}], 
      "*)"}], 
     RowBox[{
      RowBox[{"samemass", "=", 
       RowBox[{"integrand", "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"Subscript", "[", 
            RowBox[{"m", ",", "1"}], "]"}], "\[Rule]", "m"}], ",", 
          RowBox[{
           RowBox[{"Subscript", "[", 
            RowBox[{"m", ",", "2"}], "]"}], "\[Rule]", "m"}]}], "}"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"--", 
          RowBox[{"-", "Outer"}]}], " ", 
         RowBox[{"Part", "--"}]}], "-"}], "*)"}], 
      RowBox[{"f0", "=", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{"samemass", "/.", 
           RowBox[{"{", 
            RowBox[{"Q", "\[Rule]", "1"}], "}"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "order"}], "}"}]}], "]"}], "//", 
        "Normal"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"IntegrationOuter", "=", 
       RowBox[{"Integrate", "[", 
        RowBox[{"f0", ",", "s"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outer0", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"IntegrationOuter", "/.", 
            RowBox[{"{", 
             RowBox[{"s", "\[Rule]", "\[Delta]"}], "}"}]}], ")"}], "/", 
          "qplus"}], "//", "PowerExpand"}], "//", "Simplify"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"outer1", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"Series", "[", 
            RowBox[{"IntegrationOuter", ",", 
             RowBox[{"{", 
              RowBox[{"s", ",", "Infinity", ",", "0"}], "}"}]}], "]"}], "/", 
           "qplus"}], "//", "PowerExpand"}], "//", "Simplify"}], "//", 
        "Normal"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outertotal", "=", 
       RowBox[{"outer1", "-", "outer0"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outertotal", "=", 
       RowBox[{
        RowBox[{"Series", "[", 
         RowBox[{"outertotal", ",", 
          RowBox[{"{", 
           RowBox[{"m", ",", "0", ",", "order"}], "}"}]}], "]"}], "//", 
        "Normal"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
         RowBox[{"--", 
          RowBox[{"-", "Inner"}]}], " ", 
         RowBox[{"Part", "--"}]}], "-"}], "*)"}], 
      RowBox[{"inner", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Series", "[", 
           RowBox[{
            RowBox[{"Simplify", "[", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "^", "2"}], " ", "samemass"}], "/.", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"s", "\[Rule]", 
                  RowBox[{
                   RowBox[{"m", "^", "2"}], " ", "t"}]}], ",", 
                 RowBox[{"Q", "\[Rule]", "1"}]}], "}"}]}], ")"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"m", ",", "0", ",", "order"}], "}"}]}], "]"}], "//", 
          "PowerExpand"}], "//", "Simplify"}], "//", "Normal"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"IntegrationInner", "=", 
       RowBox[{"Integrate", "[", 
        RowBox[{"inner", ",", "t"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"inner0", "=", 
       RowBox[{
